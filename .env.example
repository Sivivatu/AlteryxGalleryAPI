# Alteryx Server API Configuration
# Copy this file to .env and fill in your credentials

# Required: Base URL of your Alteryx Server instance
ALTERYX_BASE_URL="https://your-server.com/webapi/"

# Required: OAuth2 Client ID (from Alteryx Server admin console)
ALTERYX_CLIENT_ID=your_client_id

# Required: OAuth2 Client Secret (from Alteryx Server admin console)
ALTERYX_CLIENT_SECRET=your_client_secret

# Optional: Owner ID for testing workflows
# TEST_OWNER_ID=id_for_test_owner

# Optional: SSL certificate verification (default: true)
# ALTERYX_VERIFY_SSL=true

# Optional: Request timeout in seconds (default: 30)
# ALTERYX_TIMEOUT=30

# Optional: Maximum retry attempts for failed requests (default: 3)
# ALTERYX_MAX_RETRIES=3

# Optional: Logging level (DEBUG, INFO, WARNING, ERROR; default: INFO)
# ALTERYX_LOG_LEVEL=INFO
